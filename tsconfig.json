{
  "compilerOptions": {
    "outDir":"./dist",
    "module":"commonjs",
    "target":"es2019",
    "esModuleInterop":true,
    "sourceMap": true,
    "rootDir": "src",
    "baseUrl": "src",
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@/*": ["*"],
    }
  },
  "include": [
    "src"
  ],
  "exclude": []
}